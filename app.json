{
  "expo": {
    "name": "Kaizen",
    "slug": "kaizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaizen.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.kaizen.app",
    "useNextNotificationsApi": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#7B2FFF"
        }
      ],
      "expo-asset"
    ],
    "scheme": "kaizen",
    "web": {
      "bundler": "metro"
    }
  }
}
